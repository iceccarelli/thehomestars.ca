// ============================================================
// RENOHUB — Prisma Schema
// Database: PostgreSQL (Supabase or Neon recommended)
// ORM: Prisma 5.x
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum QuoteStatus {
  PENDING
  QUOTED
  ACCEPTED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  CONTRACT_SENT
  SIGNED
  DEPOSIT_PAID
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  STRIPE
  BANK_TRANSFER
  PLAID
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InvoiceStage {
  DEPOSIT
  MIDPOINT
  FINAL
  CUSTOM
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  name          String?
  phone         String?
  passwordHash  String?
  role          UserRole @default(USER)
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  quoteRequests QuoteRequest[]
  projects      Project[]
  inquiries     Inquiry[]
  payments      Payment[]
  accounts      Account[]
  sessions      Session[]

  @@index([email])
}

model EmailVerificationToken {
  id           String   @id @default(uuid()) @db.Uuid
  email        String
  name         String?
  phone        String?
  passwordHash String?
  token        String   @unique @default(uuid())
  expiresAt    DateTime @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz

  @@index([token])
  @@index([email])
}

// next-auth adapter models
model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// QUOTE REQUEST
// ─────────────────────────────────────────────

model QuoteRequest {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  email       String
  phone       String?
  city        String?
  province    String?
  address     String?
  species     Json?       @db.JsonB
  squareFeet  Int?
  projectType String?
  timeline    String?
  budgetRange String?
  service     String?
  notes       String?     @db.Text
  attachments Json?       @db.JsonB
  status      QuoteStatus @default(PENDING)
  adminNotes  String?     @db.Text

  stripeCheckoutSessionId String?

  quotedAmount    Decimal?  @db.Decimal(12, 2)
  quoteTaxRate    Decimal?  @db.Decimal(5, 2)
  quoteLineItems  Json      @default("[]") @db.JsonB
  quoteNotes      String?   @db.Text
  quoteValidUntil DateTime? @db.Timestamptz
  quoteIssuedAt   DateTime? @db.Timestamptz
  quotePdfUrl     String?

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  projectId String?  @unique @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id])

  createdAt    DateTime      @default(now()) @db.Timestamptz
  updatedAt    DateTime      @updatedAt @db.Timestamptz
  appointments Appointment[]

  @@index([email])
  @@index([status])
  @@index([userId])
}

// ─────────────────────────────────────────────
// PROJECT / CONTRACT
// ─────────────────────────────────────────────

model Project {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @db.Uuid
  user         User          @relation(fields: [userId], references: [id])
  quoteRequest QuoteRequest?

  title       String
  description String?   @db.Text
  address     String?
  city        String?
  province    String?
  species     Json?     @db.JsonB
  squareFeet  Int?
  startDate   DateTime? @db.Timestamptz
  endDate     DateTime? @db.Timestamptz

  status               ProjectStatus @default(DRAFT)
  contractPdfUrl       String?
  signedContractPdfUrl String?
  contractSignedAt     DateTime?     @db.Timestamptz

  depositPct    Decimal? @default(30.00) @db.Decimal(5, 2)
  midpointPct   Decimal? @default(40.00) @db.Decimal(5, 2)
  finalPct      Decimal? @default(30.00) @db.Decimal(5, 2)
  taxRate       Decimal? @default(13.00) @db.Decimal(5, 2)
  contractValue Decimal? @db.Decimal(12, 2)

  invoices Invoice[]
  notes    ProjectNote[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([userId])
  @@index([status])
}

model ProjectNote {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz
}

// ─────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────

model Invoice {
  id        String  @id @default(uuid()) @db.Uuid
  number    String? @unique
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])

  stage  InvoiceStage?
  status InvoiceStatus @default(DRAFT)

  subtotal     Decimal @default(0) @db.Decimal(12, 2)
  discountPct  Decimal @default(0) @db.Decimal(5, 2)
  surchargePct Decimal @default(0) @db.Decimal(5, 2)
  taxRate      Decimal @default(0) @db.Decimal(5, 2)
  total        Decimal @default(0) @db.Decimal(12, 2)

  lineItems   Json      @default("[]") @db.JsonB
  description String?   @db.Text
  dueDate     DateTime? @db.Timestamptz
  issuedAt    DateTime? @db.Timestamptz
  paidAt      DateTime? @db.Timestamptz
  pdfUrl      String?

  stripePaymentIntentId String?

  payments Payment[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([projectId])
  @@index([status])
  @@index([number])
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  userId    String? @db.Uuid
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  amount Decimal       @db.Decimal(12, 2)
  method PaymentMethod?
  status PaymentStatus @default(PENDING)

  stripePaymentIntentId String?
  stripeCharged         Boolean @default(false)

  bankReference       String?
  bankConfirmedAt     DateTime? @db.Timestamptz
  bankConfirmedByNote String?

  plaidTransactionId String?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([invoiceId])
  @@index([status])
}

// ─────────────────────────────────────────────
// INQUIRY
// ─────────────────────────────────────────────

model Inquiry {
  id      String        @id @default(uuid()) @db.Uuid
  userId  String?       @db.Uuid
  user    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  name    String
  email   String
  phone   String?
  subject String?
  message String        @db.Text
  status  InquiryStatus @default(NEW)

  replies InquiryReply[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([email])
  @@index([status])
  @@index([userId])
}

model InquiryReply {
  id        String   @id @default(uuid()) @db.Uuid
  inquiryId String   @db.Uuid
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  fromAdmin Boolean  @default(false)
  content   String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz
}

// ─────────────────────────────────────────────
// GLOBAL SETTINGS (single row)
// ─────────────────────────────────────────────

model Settings {
  id String @id @default(uuid()) @db.Uuid

  defaultDepositPct  Decimal @default(30) @db.Decimal(5, 2)
  defaultMidpointPct Decimal @default(40) @db.Decimal(5, 2)
  defaultFinalPct    Decimal @default(30) @db.Decimal(5, 2)
  defaultTaxRate     Decimal @default(13) @db.Decimal(5, 2)

  companyName      String?
  companyAddress   String?
  companyPhone     String?
  companyEmail     String?
  companyNumberHst String?
  companyLogoUrl   String?

  aiEnabled Boolean @default(true)

  aiBankTransferInstructions String? @db.Text

  updatedAt DateTime @updatedAt @db.Timestamptz
}

// ─────────────────────────────────────────────
// APPOINTMENT
// ─────────────────────────────────────────────

model Appointment {
  id String @id @default(uuid()) @db.Uuid

  quoteRequestId String       @db.Uuid
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)

  startsAt        DateTime          @db.Timestamptz
  durationMinutes Int               @default(60)
  status          AppointmentStatus @default(SCHEDULED)

  customerName  String?
  customerEmail String?
  customerPhone String?
  notes         String? @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([startsAt])
  @@index([status])
  @@index([quoteRequestId])
}
